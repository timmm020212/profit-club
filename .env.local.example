# NextAuth Admin Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ВАШ_СЛОЖНЫЙ_ПАРОЛЬ
ADMIN_NAME=Администратор

# NextAuth URLs
# Для локальной разработки (обычно 3000 или 3001)
NEXTAUTH_URL=http://localhost:3000

# Сгенерируйте длинный секрет (минимум 32 символа)
# Можно сгенерировать через: openssl rand -base64 32
NEXTAUTH_SECRET=СГЕНЕРИРУЙ_ДЛИННЫЙ_СЕКРЕТ_ЗДЕСЬ

# Если у вас есть Telegram-бот токены (уже должны быть в других .env файлах)
# TELEGRAM_BOT_TOKEN=...
# MASTERS_BOT_TOKEN=...
